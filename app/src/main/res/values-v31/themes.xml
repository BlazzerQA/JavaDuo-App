<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.JavaDuoApp" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Theme для API 31+ с улучшенной анимацией -->
    <style name="Theme.JavaDuoApp.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D1117</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="windowSplashScreenIconBackgroundColor">#0D1117</item>
        <item name="postSplashScreenTheme">@style/Theme.JavaDuoApp</item>
    </style>
</resources>
